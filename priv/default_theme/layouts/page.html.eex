<main id="main">
  <article class="container-content page-wrapper">
    <%= @block.(:breadcrumb, []) %>
    <header class="content-header-sm">
      <h1 class="page-title-lg"><%= @content.title %></h1>
    </header>
    <div class="article-content">
      <%= @inner_content %>
    </div>
  </article>
</main>
